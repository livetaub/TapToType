<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- ==========================================
             TOP BAR: Always visible
             ========================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp">

            <!-- Left: Title + optional connected subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- App title row — always visible -->
                <LinearLayout
                    android:id="@+id/appTitleRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@mipmap/ic_launcher"
                        android:contentDescription="TapToType"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/appTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TapToType"
                        android:textSize="22sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.02" />
                </LinearLayout>

                <!-- Connected subtitle — shown when connected -->
                <LinearLayout
                    android:id="@+id/connectedBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="2dp"
                    android:visibility="gone">

                    <View
                        android:id="@+id/statusIndicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/status_connected"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: Settings OR ellipsis -->
            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="Settings"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/connectedMenuButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="Menu"
                android:padding="10dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ==========================================
             DISCONNECTED STATE
             ========================================== -->
        <LinearLayout
            android:id="@+id/disconnectedSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tagline -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Turn your phone into a Bluetooth keyboard"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:letterSpacing="0.01"
                android:layout_marginBottom="28dp" />

            <!-- Status info card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/disconnectedDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/status_disconnected"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/deviceListLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Not connected"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Saved device cards -->
            <LinearLayout
                android:id="@+id/savedDevicesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Setup button -->
            <Button
                android:id="@+id/addNewDeviceButton"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Set Up New Device"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="8dp" />

            <!-- Connect prompt — Empty state -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="48dp"
                android:paddingBottom="48dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_link"
                    android:contentDescription="Connect"
                    android:alpha="0.5"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connect to a device to start typing"
                    android:textSize="16sp"
                    android:textColor="@color/text_tertiary"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ==========================================
             CONNECTED STATE — Typing UI
             ========================================== -->
        <LinearLayout
            android:id="@+id/typingSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Mode Selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Typing mode"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginEnd="14dp" />

                    <Spinner
                        android:id="@+id/modeSpinner"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_background"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:popupBackground="@color/surface"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <TextView
                    android:id="@+id/modeHelperText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Each keystroke is sent to your PC instantly"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:fontFamily="sans-serif"
                    android:paddingTop="8dp"
                    android:paddingStart="2dp" />
            </LinearLayout>

            <!-- Input Area (FrameLayout to overlay echo in live mode) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp">

                <com.taptotype.HidEditText
                    android:id="@+id/inputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:background="@drawable/input_background"
                    android:padding="20dp"
                    android:textSize="17sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:hint="Start typing — keystrokes sent live…"
                    android:fontFamily="sans-serif"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:importantForAutofill="no"
                    android:lineSpacingExtra="6dp"
                    android:scrollbars="vertical"
                    android:overScrollMode="always"
                    tools:ignore="LabelFor" />

                <!-- Live Echo Display (shown only in live mode) -->
                <LinearLayout
                    android:id="@+id/liveEchoScroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Single character echo display -->
                    <TextView
                        android:id="@+id/liveEchoText"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:textSize="64sp"
                        android:textColor="@color/text_tertiary"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:padding="20dp" />

                    <!-- Always-visible tap hint button -->
                    <Button
                        android:id="@+id/liveEchoHint"
                        style="@style/SecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Tap here to display keyboard"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:drawableStart="@drawable/ic_keyboard"
                        android:drawablePadding="10dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:id="@+id/actionButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="12dp">

                <ImageButton
                    android:id="@+id/sendButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_send"
                    android:background="@drawable/button_primary_bg"
                    android:scaleType="centerInside"
                    android:contentDescription="Send"
                    android:visibility="gone"
                    android:layout_marginEnd="12dp"
                    android:padding="16dp" />

                <ImageButton
                    android:id="@+id/historyButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_history"
                    android:background="@drawable/button_secondary_bg"
                    android:scaleType="centerInside"
                    android:contentDescription="History"
                    android:visibility="gone"
                    android:layout_marginEnd="12dp"
                    android:padding="14dp" />

                <Button
                    android:id="@+id/clearButton"
                    style="@style/SecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Clear"
                    android:textColor="@color/button_secondary_text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>

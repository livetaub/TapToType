<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:padding="28dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connect to your PC"
        android:textSize="24sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="-0.02"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Follow these steps to pair and connect"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:layout_marginBottom="4dp" />

    <!-- Step counter -->
    <TextView
        android:id="@+id/wizardStepCounter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Step 1 of 5"
        android:textSize="13sp"
        android:textColor="@color/accent"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Step Progress Indicators -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="28dp">

        <View
            android:id="@+id/wizardDot1"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/wizard_dot_inactive" />

        <View
            android:layout_width="28dp"
            android:layout_height="2dp"
            android:background="@color/divider"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/wizardDot2"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/wizard_dot_inactive" />

        <View
            android:layout_width="28dp"
            android:layout_height="2dp"
            android:background="@color/divider"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/wizardDot3"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/wizard_dot_inactive" />

        <View
            android:layout_width="28dp"
            android:layout_height="2dp"
            android:background="@color/divider"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/wizardDot4"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/wizard_dot_inactive" />

        <View
            android:layout_width="28dp"
            android:layout_height="2dp"
            android:background="@color/divider"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/wizardDot5"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/wizard_dot_inactive" />
    </LinearLayout>

    <!-- Step Number Badge -->
    <TextView
        android:id="@+id/wizardStepBadge"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="1"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:background="@drawable/step_badge_bg"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Step Title -->
    <TextView
        android:id="@+id/wizardStepTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Bluetooth"
        android:textSize="20sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="-0.01"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Step Description -->
    <TextView
        android:id="@+id/wizardStepDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Make sure Bluetooth is turned on."
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="5dp"
        android:layout_marginBottom="8dp" />

    <!-- Step Hint -->
    <TextView
        android:id="@+id/wizardStepHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="@color/text_tertiary"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="20dp" />

    <!-- Status indicator for auto-detectable steps -->
    <LinearLayout
        android:id="@+id/wizardStatusRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        android:background="@drawable/card_background"
        android:padding="14dp"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/wizardStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_disconnected"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/wizardStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not detected"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Step Action Button -->
    <Button
        android:id="@+id/wizardActionButton"
        style="@style/SecondaryButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Action"
        android:textColor="@color/button_secondary_text"
        android:textSize="15sp"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <!-- Inline device list (Step 5 only) -->
    <ScrollView
        android:id="@+id/wizardDeviceListScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="180dp"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/wizardDeviceList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Success overlay (shown when connected) -->
    <LinearLayout
        android:id="@+id/wizardSuccessOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="48sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You're connected!"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/wizardSuccessDevice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connected to your PC"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Click any text field on your PC and start typing!"
            android:textSize="14sp"
            android:textColor="@color/text_tertiary"
            android:gravity="center" />
    </LinearLayout>

    <!-- Navigation Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/wizardBackButton"
            style="@style/SecondaryButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Back"
            android:textColor="@color/button_secondary_text"
            android:textSize="15sp"
            android:visibility="gone"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/wizardNextButton"
            style="@style/PrimaryButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Next"
            android:textSize="15sp"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- Dismiss -->
    <TextView
        android:id="@+id/wizardDismissButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="I'll do this later"
        android:textSize="14sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="4dp" />

    <!-- Help link -->
    <TextView
        android:id="@+id/wizardHelpButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Need help?"
        android:textSize="14sp"
        android:textColor="@color/text_accent"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="4dp" />

</LinearLayout>
